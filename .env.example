APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=elections
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration
# For testing, use Mailtrap (https://mailtrap.io):
# 1. Sign up and create an inbox
# 2. Go to SMTP settings and select "Laravel 9+"
# 3. Copy the credentials below

# Mailtrap SMTP Settings (for testing)
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_FROM_ADDRESS="elections@example.com"
MAIL_FROM_NAME="Election System"

# For production, use your actual SMTP settings:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.yourprovider.com
# MAIL_PORT=587
# MAIL_USERNAME=your_email@example.com
# MAIL_PASSWORD=your_password
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS="elections@yourdomain.com"
# MAIL_FROM_NAME="Election System"

# SMS Provider Configuration
# Supported: twilio, africastalking, vonage, custom
SMS_PROVIDER=twilio

# Phone Number Formatting
# Set country code for numbers without + prefix (e.g., 264 for Namibia, 254 for Kenya)
SMS_DEFAULT_COUNTRY_CODE=264

# Set to 'false' if all your phone numbers already include + country code
# Set to 'true' if some numbers are local format (e.g., 0814686622 → +264814686622)
SMS_NORMALIZE_NUMBERS=true

# Twilio Configuration (for testing)
# 1. Sign up at https://www.twilio.com/try-twilio
# 2. Get your Account SID and Auth Token from the console dashboard
# 3. Get a phone number (trial number works for testing)
# 4. For trial accounts, you can only send to verified phone numbers
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=your_twilio_phone_number

# Africa's Talking Configuration
AT_USERNAME=
AT_API_KEY=
AT_FROM=

# Vonage (Nexmo) Configuration
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM=ElectionApp

# Custom SMS API Configuration
SMS_CUSTOM_ENDPOINT=
SMS_CUSTOM_API_KEY=
SMS_CUSTOM_FORMAT=json

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
